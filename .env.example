# --- Deployment Mode ---
# Set to "true" when deployed on Render (disables local-only features)
RENDER=false
# Set to "true" when running in Docker
DOCKER=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Leave empty for SQLite (local). Set to PostgreSQL connection string for deployment:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# --- Paths ---
UPLOAD_DIR=./uploads
MODELS_DIR=./models
DATABASE_DIR=./database

# --- LLM Model ---
# Set USE_MODEL=false to disable model loading (e.g., on Render)
USE_MODEL=true
LLM_MODEL_NAME=phi-3-mini-4k-instruct-q4.gguf
LLM_MODEL_PATH=./models/phi-3-mini-4k-instruct-q4.gguf
MODEL_CONTEXT=2048
# 0 = auto-detect CPU cores
MODEL_THREADS=0

# --- OCR ---
# Set USE_OCR=false to disable OCR (e.g., on Render)
USE_OCR=true
OCR_LANGUAGE=eng
# Path to Tesseract executable (leave empty for system default)
TESSERACT_PATH=
# Path to Poppler bin directory (leave empty for system default)
POPPLER_PATH=
